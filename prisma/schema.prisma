generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Customer {
  id            String   @id
  companyName   String
  email         String?
  createdAt     DateTime
  updatedAt     DateTime @updatedAt
  orders        Order[]
}

model Order {
  id               String     @id            // Printavo ID
  visualId         String?                   // e.g., "12345"
  type             OrderType                 // QUOTE or INVOICE
  status           String                    // Printavo status name
  statusCategory   String                    // our derived category
  subtotal         Float
  total            Float
  customerId       String
  customer         Customer   @relation(fields: [customerId], references: [id])
  orderDate        DateTime                  // when created in Printavo
  dueDate          DateTime?                 // customer due / in-hands
  completedAt      DateTime?                 // first time it entered a COMPLETE status
  voided           Boolean    @default(false)
  lastSyncedAt     DateTime   @default(now())
  lineItems        LineItem[]

  @@index([orderDate])
  @@index([dueDate])
  @@index([statusCategory])
  @@index([customerId])
}

enum OrderType {
  QUOTE
  INVOICE
}

model LineItem {
  id           String   @id
  orderId      String
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  description  String
  quantity     Int
  price        Float
  typeOfWork   String?                       // Embroidery, Screen Printing, etc.

  @@index([orderId])
  @@index([typeOfWork])
}

model StatusHistory {
  id         String   @id @default(cuid())
  orderId    String
  status     String
  category   String
  changedAt  DateTime

  @@index([orderId, changedAt])
}

model SyncLog {
  id         String   @id @default(cuid())
  kind       String                          // "backfill", "webhook", "cron"
  status     String                          // "success", "error"
  message    String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
}